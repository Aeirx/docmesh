# DocMesh configuration. Copy to .env and edit. Every variable has a sane default;
# an empty .env (or no .env at all) runs the full local stack.

# Runtime environment: dev | prod | test (controls log rendering: console vs JSON)
DOCMESH_ENV=dev

# Directory for the SQLite DB, uploaded files, and (Phase 2) the vector index
DOCMESH_DATA_DIR=./data

# SQLAlchemy async URL. Swap to Postgres with e.g.
#   postgresql+asyncpg://user:pass@host:5432/docmesh   (and `pip install asyncpg`)
DOCMESH_DATABASE_URL=sqlite+aiosqlite:///./data/docmesh.db

# Hard cap on a single upload, enforced while streaming (Content-Length is never trusted)
DOCMESH_MAX_UPLOAD_MB=25

# JSON list of allowed browser origins for CORS
DOCMESH_CORS_ORIGINS=["http://localhost:5173"]

# Nested settings use a double underscore: DOCMESH_<SECTION>__<FIELD>
# Chunking (Phase 2)
#DOCMESH_CHUNKING__TARGET_TOKENS=400
#DOCMESH_CHUNKING__OVERLAP_RATIO=0.15
#DOCMESH_CHUNKING__NEAR_DUP_COSINE=0.98

# Hybrid search (Phase 2)
#DOCMESH_SEARCH__DENSE_MODEL=BAAI/bge-small-en-v1.5
#DOCMESH_SEARCH__RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
#DOCMESH_SEARCH__RRF_K=60
#DOCMESH_SEARCH__DENSE_WEIGHT=0.5
#DOCMESH_SEARCH__RETRIEVE_N=30
#DOCMESH_SEARCH__RETURN_N=10

# Document graph (Phase 3)
#DOCMESH_GRAPH__SEMANTIC_WEIGHT=0.5
#DOCMESH_GRAPH__ENTITY_WEIGHT=0.3
#DOCMESH_GRAPH__TOPIC_WEIGHT=0.2
#DOCMESH_GRAPH__EDGE_THRESHOLD=0.35
#DOCMESH_GRAPH__TOP_K_PAIRS=10

# Local LLM explanations (Phase 4). Fully local — no API keys, nothing leaves
# the machine. ENABLED=false degrades to deterministic template explanations;
# AUTO_DOWNLOAD=false makes a missing model file degrade instead of download
# (~1 GB from Hugging Face into data/models/ on first use otherwise).
#DOCMESH_LLM__ENABLED=true
#DOCMESH_LLM__REPO_ID=Qwen/Qwen2.5-1.5B-Instruct-GGUF
#DOCMESH_LLM__FILENAME=qwen2.5-1.5b-instruct-q4_k_m.gguf
#DOCMESH_LLM__MODEL_PATH=            # absolute path to a local .gguf; skips download
#DOCMESH_LLM__AUTO_DOWNLOAD=true
#DOCMESH_LLM__N_THREADS=             # blank -> llama.cpp picks physical cores
#DOCMESH_LLM__MAX_TOKENS=220
#DOCMESH_LLM__RPM_LIMIT=6
#DOCMESH_LLM__WARM=false             # load (maybe download) the model at startup
