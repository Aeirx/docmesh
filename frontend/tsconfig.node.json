{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "node_modules/.tmp/tsconfig.node",
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
